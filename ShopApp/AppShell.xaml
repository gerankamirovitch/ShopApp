<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:ShopApp.Views"
       x:Class="ShopApp.AppShell">
    <TabBar>
        <Tab Title="Число" Icon="reverse.png">
            <ShellContent ContentTemplate="{DataTemplate views:ReverseNumberPage}"/>
        </Tab>
        <Tab Title="Классы" Icon="classes.png">
            <ShellContent ContentTemplate="{DataTemplate views:ClassesPage}"/>
        </Tab>
        <Tab Title="Товар" Icon="product.png">
            <ShellContent ContentTemplate="{DataTemplate views:ProductClassPage}"/>
        </Tab>
        <Tab Title="Главная" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate views:MainShopPage}"/>
        </Tab>
        <Tab Title="Корзина" Icon="cart.png">
            <ShellContent ContentTemplate="{DataTemplate views:CartPage}"/>
        </Tab>
        <Tab Title="Детали" Icon="detail.png">
            <ShellContent ContentTemplate="{DataTemplate views:ProductDetailPage}"/>
        </Tab>
    </TabBar>
</Shell>