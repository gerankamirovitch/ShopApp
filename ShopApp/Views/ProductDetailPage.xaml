<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ShopApp.Converters"
             x:Class="ShopApp.Views.ProductDetailPage"
             Title="Детали товара">
    <ContentPage.Resources>
        <converters:RatingToStarsConverter x:Key="RatingToStarsConverter" />
        <converters:StockGreaterThanZeroConverter x:Key="StockGreaterThanZeroConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <CarouselView x:Name="carousel" HeightRequest="400" Loop="False">
                <CarouselView.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>phone_front.png</x:String>
                        <x:String>phone_back.png</x:String>
                        <x:String>phone_side.png</x:String>
                    </x:Array>
                </CarouselView.ItemsSource>
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Image Source="{Binding .}" 
                   Aspect="AspectFit" 
                   HeightRequest="400"/>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <Label Text="{Binding Name}" Style="{StaticResource TitleLabel}"/>
            <Label Text="{Binding DisplayPrice}" FontSize="28" TextColor="{StaticResource Success}" HorizontalOptions="Center"/>

            <Grid ColumnDefinitions="Auto, Auto, *">
                <Label Grid.Column="0" Text="Рейтинг:   " FontSize="Medium" TextColor="#000000"/>
                <Label Grid.Column="1" Text="★★★★☆     " FontSize="Medium" FontAttributes="Bold" TextColor="Gold"/>
            </Grid>

            <Frame>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Описание" Style="{StaticResource SubtitleLabel}"/>
                    <Label Text="Смартфон Obeme Pro — это новейшее устройство с потрясающим дисплеем, мощным процессором и профессиональной камерой. Идеально подходит для фотосъёмки, игр и работы. Благодаря большому аккумулятору вы сможете пользоваться им весь день без подзарядки."
                           FontSize="Body"/>
                </VerticalStackLayout>
            </Frame>

            <Frame>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Характеристики" Style="{StaticResource SubtitleLabel}"/>
                    <Label Text="• Дисплей: 6.7 дюйма Super Retina XDR&#xA;• Процессор: A16 Bionic&#xA;• Память: 256 ГБ&#xA;• Камера: 48+12+12 МП&#xA;• Аккумулятор: 4323 мАч&#xA;• Защита: IP68"
                           FontSize="Body"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Блок выбора количества с ручным вводом и отображением остатка -->
            <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,10">
                <Label Grid.Column="0" Text="Количество:" VerticalOptions="Center" TextColor="#000000"/>
                <Entry x:Name="quantityEntry" 
                       Grid.Column="1" 
                       Keyboard="Numeric"
                       Placeholder="1"
                       Text="1"
                       IsEnabled="{Binding Stock, Converter={StaticResource StockGreaterThanZeroConverter}}"
                       HorizontalOptions="FillAndExpand"
                       Margin="10,0"
                       TextChanged="quantityEntry_TextChanged"/>
                <Label Grid.Column="2" 
                       Text="{Binding Stock, StringFormat='Доступно: {0}'}" 
                       VerticalOptions="Center"
                       TextColor="{StaticResource Gray600}"/>
            </Grid>

            <Button Text="Добавить в корзину" 
                    Clicked="OnAddToCartClicked"
                    BackgroundColor="{StaticResource Success}"/>
            <Button Text="Купить сейчас" 
                    Clicked="OnBuyNowClicked"
                    BackgroundColor="{StaticResource Accent}"/>

            <Frame>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Отзывы покупателей" Style="{StaticResource SubtitleLabel}"/>
                    <Label Text="★★★★★     Телефон супер" FontSize="Medium" FontAttributes="Bold" TextColor="#000000" Style="{StaticResource SubtitleLabel}"/>
                    <Label Text="★★★★★     Отличное качество" FontSize="Medium" FontAttributes="Bold" TextColor="#000000" Style="{StaticResource SubtitleLabel}"/>
                    <Label Text="★★★★☆     Очень хороший телефон" FontSize="Medium" FontAttributes="Bold" TextColor="#000000" Style="{StaticResource SubtitleLabel}"/>
                    <Label Text="★★★★☆     Хоший, но не идеал" FontSize="Medium" FontAttributes="Bold" TextColor="#000000" Style="{StaticResource SubtitleLabel}"/>
                    <Label Text="★★☆☆☆     Ужасный за свою цену" FontSize="Medium" FontAttributes="Bold" TextColor="#000000" Style="{StaticResource SubtitleLabel}"/>
                    <CollectionView x:Name="reviewsCollection" 
                                    ItemsSource="{Binding Reviews}"
                                    HeightRequest="80">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Spacing="5" Margin="0,5">
                                    <Grid ColumnDefinitions="Auto, Auto, *">
                                        <Label Grid.Column="0" Text="{Binding UserName}" FontAttributes="Bold"/>
                                        <Label Grid.Column="1" Text="{Binding Rating, Converter={StaticResource RatingToStarsConverter}}" Margin="10,0"/>
                                        <Label Grid.Column="2" Text="{Binding Date, StringFormat='dd.MM.yyyy'}" HorizontalOptions="End" FontSize="Small"/>
                                    </Grid>
                                    <Label Text="{Binding Comment}" FontSize="Small"/>
                                    <BoxView HeightRequest="1" Color="{StaticResource GrayLight}"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>