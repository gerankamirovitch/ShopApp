<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShopApp.Views.CartPage"
             Title="Корзина">
    <VerticalStackLayout Padding="20" Spacing="20">
        <Label Text="Ваша корзина" Style="{StaticResource TitleLabel}" TextColor="#000000"/>
        <CollectionView x:Name="cartCollection" ItemsSource="{Binding}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5">
                        <Grid ColumnDefinitions="80, *, Auto">
                            <Image Grid.Column="0" Source="{Binding Product.ImageUrl}" HeightRequest="80"/>
                            <VerticalStackLayout Grid.Column="1" Padding="10,0">
                                <Label Text="{Binding Product.Name}" FontAttributes="Bold"/>
                                <Label Text="{Binding Product.DisplayPrice}" TextColor="{StaticResource Success}"/>
                                <Label Text="{Binding Quantity, StringFormat='Количество: {0}'}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="{Binding Total, StringFormat='{0:C}'}" VerticalOptions="Center"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Label x:Name="totalLabel" FontSize="Large" HorizontalOptions="Center"/>
        <Button Text="Оформить заказ" Clicked="OnCheckoutClicked"/>
    </VerticalStackLayout>
</ContentPage>